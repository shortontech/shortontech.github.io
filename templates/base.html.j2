<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description }}" />
    <title>{{ title }}</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="{{ asset_prefix }}assets/css/site.css" />
  </head>
  <body class="bg-stone-50 text-zinc-950 antialiased">
    <header class="border-b border-zinc-200 bg-stone-50/90 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-8">
        <a href="{{ site_root }}" class="flex items-center gap-3">
          <span class="grid size-9 place-items-center rounded-md border-2 border-zinc-950 font-black text-teal-700">S</span>
          <span class="font-bold tracking-tight">Steven Horton</span>
        </a>
        <nav class="hidden items-center gap-6 text-sm font-medium text-zinc-600 md:flex">
          <a class="hover:text-zinc-950" href="{{ site_root }}#whitepapers">Whitepapers</a>
          <a class="hover:text-zinc-950" href="{{ site_root }}#systems">Systems</a>
          <a class="hover:text-zinc-950" href="{{ site_root }}#resume">Resume</a>
          <a class="hover:text-zinc-950" href="{{ site_root }}#contact">Contact</a>
        </nav>
      </div>
    </header>

    {% block body %}{% endblock %}
  </body>
</html>

