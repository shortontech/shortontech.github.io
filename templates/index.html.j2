{% extends "base.html.j2" %}

{% block body %}
<main>
  <section class="mx-auto max-w-7xl px-5 py-12 sm:px-8 lg:py-16">
    <div>
      <p class="mb-4 text-sm font-black uppercase tracking-wide text-red-700">Application Security Engineer</p>
      <h1 class="max-w-5xl text-5xl font-black leading-[0.96] tracking-normal text-zinc-950 sm:text-6xl lg:text-7xl">
        Whitepapers on proof-driven security engineering.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-700">
        I build and write about deterministic security systems: framework-aware
        static analysis, browser-observed dynamic testing, AI-assisted review,
        and secure code generation that produce auditable evidence instead of
        alert noise.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded-md bg-zinc-950 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-800" href="#whitepapers">
          Read whitepapers
        </a>
        <a class="rounded-md border border-zinc-950 px-5 py-3 text-sm font-bold text-zinc-950 hover:bg-white" href="#resume">
          View resume
        </a>
      </div>
    </div>
  </section>

  <section id="whitepapers" class="border-t border-zinc-200 bg-white py-12">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="text-sm font-black uppercase tracking-wide text-red-700">Whitepapers</p>
          <h2 class="mt-2 text-4xl font-black tracking-normal">Publication Queue</h2>
          <p class="mt-4 max-w-2xl leading-7 text-zinc-700">
            Durable research artifacts on application security, static analysis,
            dynamic testing, AI-assisted review, and secure code generation.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 text-sm font-bold">
          {% for tag in featured_tags %}
          <span class="rounded-full border border-zinc-300 px-3 py-2">{{ tag.label }}</span>
          {% endfor %}
        </div>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {% for paper in papers %}
        <article class="rounded-lg border border-zinc-200 bg-stone-50 p-6">
          <p class="text-xs font-black uppercase tracking-wide text-teal-700">{{ paper.display_date }}</p>
          <h3 class="mt-3 text-2xl font-black">
            <a class="hover:text-teal-800" href="whitepapers/{{ paper.slug }}/">{{ paper.title }}</a>
          </h3>
          <p class="mt-4 leading-7 text-zinc-700">{{ paper.summary }}</p>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-bold text-zinc-600">
            {% for tag in paper.tag_items %}
            <span class="rounded-full bg-white px-3 py-2">{{ tag.label }}</span>
            {% endfor %}
          </div>
          <div class="mt-6 flex flex-wrap gap-3 text-sm font-bold">
            <a class="text-teal-800 hover:text-teal-950" href="whitepapers/{{ paper.slug }}/">Read HTML</a>
            <a class="text-teal-800 hover:text-teal-950" href="dist/whitepapers/{{ paper.slug }}.pdf">Download PDF</a>
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section id="systems" class="border-t border-zinc-200 py-16">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <p class="text-sm font-black uppercase tracking-wide text-red-700">Open Source</p>
      <h2 class="mt-2 text-4xl font-black tracking-normal">
        <a class="hover:text-teal-800" href="https://github.com/shortontech/pickle">Pickle: secure backend generation for Go</a>
      </h2>
      <div class="mt-8 grid gap-4 lg:grid-cols-[minmax(0,0.82fr)]">
        <div class="rounded-lg border border-zinc-200 bg-white p-6">
          <h3 class="text-2xl font-black">
            <a class="hover:text-teal-800" href="https://github.com/shortontech/pickle">From schema to enforceable backend structure</a>
          </h3>
          <p class="mt-3 leading-7 text-zinc-700">
            Pickle is an open-source secure backend generator for Go services.
            It turns declared models, relationships, ownership rules, and
            exposure intent into repository-owned code: request binding, typed
            query builders, service scaffolding, RBAC-aware handlers, GraphQL
            exposure controls, and generated metadata that security tooling can
            inspect.
          </p>
          <p class="mt-4 leading-7 text-zinc-700">
            The goal is to make the secure path the normal path. Pickle encodes
            backend decisions that are easy to miss in hand-written services:
            who owns a record, which fields may cross an API boundary, which
            routes require authorization, and which generated surfaces should
            stay consistent as the application changes.
          </p>
          <p class="mt-4 leading-7 text-zinc-700">
            Its Squeeze checks turn those expectations into repeatable review.
            Instead of relying on memory during every pull request, the repository
            can run checks for authorization drift, unsafe exposure, route
            posture, query shape, and generated-code consistency.
          </p>
          <a class="mt-5 inline-flex rounded-md border border-zinc-950 px-4 py-2 text-sm font-bold hover:bg-stone-50" href="https://github.com/shortontech/pickle">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <section id="resume" class="border-t border-zinc-200 bg-zinc-950 py-16 text-white">
    <div class="mx-auto grid max-w-7xl gap-10 px-5 sm:px-8 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-amber-300">Experience</p>
        <h2 class="mt-2 text-4xl font-black tracking-normal">15+ years building and securing software.</h2>
        <p class="mt-5 leading-8 text-zinc-300">
          Financial systems, cryptocurrency exchange modernization, analytics
          platforms, incident response, DevSecOps, AI risk assessment, and
          security-tooling systems.
        </p>
      </div>
      <div class="grid gap-4">
        <div class="rounded-lg border border-white/15 bg-white/5 p-5">
          <h3 class="font-black">Telhawk Systems, Inc.</h3>
          <p class="mt-2 text-zinc-300">Co-founder building a self-improving security analysis harness combining deterministic SAST with AI-assisted review.</p>
        </div>
        <div class="rounded-lg border border-white/15 bg-white/5 p-5">
          <h3 class="font-black">Bitcoin Solutions</h3>
          <p class="mt-2 text-zinc-300">Senior Security Software Engineer modernizing exchange backends and enforcing release security safeguards.</p>
        </div>
        <div class="rounded-lg border border-white/15 bg-white/5 p-5">
          <h3 class="font-black">SDK Worldwide / Capital Research / MAS Group</h3>
          <p class="mt-2 text-zinc-300">Security-conscious engineering across ETL, analytics, fraud detection, e-commerce, legacy PHP, and infrastructure hardening.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="border-t border-zinc-200 bg-white py-12">
    <div class="mx-auto flex max-w-7xl flex-col justify-between gap-6 px-5 sm:px-8 md:flex-row md:items-center">
      <div>
        <h2 class="text-3xl font-black">Contact</h2>
        <p class="mt-2 text-zinc-700">Application security engineering, secure analysis systems, and whitepaper collaboration.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a class="rounded-md bg-zinc-950 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-800" href="mailto:shorton.tech@gmail.com">Email</a>
        <a class="rounded-md border border-zinc-950 px-5 py-3 text-sm font-bold hover:bg-stone-50" href="https://github.com/shortontech">GitHub</a>
      </div>
    </div>
  </section>
</main>
{% endblock %}
